# Later Letters — Environment Variables
# Copy these into Railway → your project → Variables tab
# Never commit this file to GitHub with real values filled in!

# ── SUPABASE ──────────────────────────────────────────────────────
# Found in: Supabase → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJ...YOUR_SERVICE_ROLE_KEY...

# ── MAILGUN ───────────────────────────────────────────────────────
# Found in: Mailgun → Settings → API Keys (or Domain Settings)
MAILGUN_WEBHOOK_KEY=key-YOUR_MAILGUN_API_KEY

# ── SERVER ────────────────────────────────────────────────────────
# Railway sets PORT automatically — leave this as is
PORT=3000
